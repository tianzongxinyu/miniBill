ALLOW_REGISTRATION=true
# docker compose -f docker-compose.prod.yml 拉镜像时填写，例如 yourname/minibill:latest
# MINIBILL_IMAGE=yourname/minibill:latest
DATA_DIR=./data
PORT=8080
JWT_EXPIRE_DAYS=30
TZ=Asia/Shanghai
BACKUP_DIR=
STATIC_DIR=./web/out
MIGRATIONS_SYSTEM=./migrations/system
MIGRATIONS_LEDGER=./migrations/ledger
GIN_MODE=release
# 生产环境 HTTPS 反代时设为 true
SECURE_COOKIES=false
